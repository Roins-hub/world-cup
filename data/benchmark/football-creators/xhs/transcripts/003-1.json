    {
      "start": 425.12,
      "end": 426.96,
      "text": "这是一只王者之师啊"
    },
    {
      "start": 426.96,
      "end": 428.24,
      "text": "团结的球队"
    },
    {
      "start": 428.24,
      "end": 430.44,
      "text": "一直在严密的掌控"
    },
    {
      "start": 430.44,
      "end": 432.68,
      "text": "这场比赛足球的节奏"
    },
    {
      "start": 432.68,
      "end": 434.8,
      "text": "就像掌控精密仪器一样"
    },
    {
      "start": 434.8,
      "end": 437.0,
      "text": "但当他想要提速的时候"
    },
    {
      "start": 437.0,
      "end": 438.88,
      "text": "最后一般球队是防不住的"
    },
    {
      "start": 438.88,
      "end": 439.8,
      "text": "当皇"
    },
    {
      "start": 439.8,
      "end": 441.56,
      "text": "对路就得跑就得拼"
    },
    {
      "start": 441.56,
      "end": 442.48,
      "text": "底线处有人"
    },
    {
      "start": 442.48,
      "end": 443.44,
      "text": "麦卡丽斯特"
    },
    {
      "start": 443.44,
      "end": 444.28,
      "text": "直接打门"
    },
    {
      "start": 444.28,
      "end": 445.64,
      "text": "门将拖手了"
    },
    {
      "start": 445.68,
      "end": 448.08,
      "text": "镜头能不能找找他爹"
    },
    {
      "start": 448.08,
      "end": 448.84,
      "text": "爹回家说"
    },
    {
      "start": 448.84,
      "end": 449.76,
      "text": "我冲你是二十角"
    },
    {
      "start": 449.76,
      "end": 452.68,
      "text": "看你拖手有几次"
    },
    {
      "start": 452.68,
      "end": 453.8,
      "text": "梅西"
    },
    {
      "start": 453.8,
      "end": 454.6,
      "text": "打入了"
    },
    {
      "start": 454.6,
      "end": 460.97,
      "text": "本场比赛第二立进球"
    },
    {
      "start": 460.97,
      "end": 462.53,
      "text": "往哪边来"
    },
    {
      "start": 462.53,
      "end": 463.17,
      "text": "朝右侧给"
    },
    {
      "start": 463.17,
      "end": 464.57,
      "text": "德炮出角能够拦到"
    },
    {
      "start": 464.57,
      "end": 466.29,
      "text": "挑球摆脱"
    },
    {
      "start": 466.29,
      "end": 467.17,
      "text": "嘿呦我的天呐"
    },
    {
      "start": 467.17,
      "end": 469.09,
      "text": "德炮在场对手插上"
    },
    {
      "start": 469.09,
      "end": 469.97,
      "text": "优雅"
    },
    {
      "start": 469.97,
      "end": 470.61,
      "text": "我说实在"
    },
    {
      "start": 470.61,
      "end": 471.97,
      "text": "德炮比二十年的时候"
    },
    {
      "start": 471.97,
      "end": 472.85,
      "text": "踢得要细"
    },
    {
      "start": 472.85,
      "end": 474.61,
      "text": "哈哈哈哈哈哈"
    },
    {
      "start": 476.05,
      "end": 477.45,
      "text": "拿球又摆脱"
    },
    {
      "start": 477.45,
      "end": 478.37,
      "text": "拿球又摆脱"
    },
    {
      "start": 478.37,
      "end": 478.89,
      "text": "哇"
    },
    {
      "start": 478.89,
      "end": 480.13,
      "text": "这小球又给过来了"
    },
    {
      "start": 480.13,
      "end": 481.57,
      "text": "梅西梅西有机会"
    },
    {
      "start": 481.57,
      "end": 483.57,
      "text": "要少眼帽子洗发吧"
    },
    {
      "start": 483.57,
      "end": 486.45,
      "text": "其他内不解风情啊"
    },
    {
      "start": 486.45,
      "end": 487.29,
      "text": "你以后啊"
    },
    {
      "start": 487.29,
      "end": 488.01,
      "text": "小镇诅咒你"
    },
    {
      "start": 488.01,
      "end": 492.92,
      "text": "你以后会突头"
    },
    {
      "start": 492.92,
      "end": 494.44,
      "text": "这不就逼向成功了吗"
    },
    {
      "start": 494.44,
      "end": 495.08,
      "text": "二瓦雷斯"
    },
    {
      "start": 495.08,
      "end": 495.64,
      "text": "二瓦雷斯"
    },
    {
      "start": 495.64,
      "end": 496.84,
      "text": "还是从容把球分出去了"
    },
    {
      "start": 496.84,
      "end": 498.28,
      "text": "这梅西倒地"
    },
    {
      "start": 498.28,
      "end": 499.2,
      "text": "彩盘"
    },
    {
      "start": 499.2,
      "end": 504.94,
      "text": "彩盘"
    },
    {
      "start": 504.94,
      "end": 511.3,
      "text": "你臭光头"
    },
    {
      "start": 511.3,
      "end": 521.18,
      "text": "这怎么不看呢"
    },
    {
      "start": 521.18,
      "end": 522.42,
      "text": "梅西"
    },
    {
      "start": 522.42,
      "end": 523.74,
      "text": "给了把球给到梅西的小下"
    },
    {
      "start": 523.74,
      "end": 524.46,
      "text": "想不想这段时间"
    },
    {
      "start": 524.46,
      "end": 525.62,
      "text": "踢的是很舒服呀"
    },
    {
      "start": 525.62,
      "end": 526.22,
      "text": "刚晃"
    },
    {
      "start": 526.22,
      "end": 527.3,
      "text": "看你的横船"
    },
    {
      "start": 527.3,
      "end": 528.3,
      "text": "横船扫过来"
    },
    {
      "start": 528.3,
      "end": 529.14,
      "text": "梅西那就"
    },
    {
      "start": 529.14,
      "end": 529.74,
      "text": "来吧"
    },
    {
      "start": 529.78,
      "end": 530.82,
      "text": "直接起脚"
    },
    {
      "start": 530.82,
      "end": 532.26,
      "text": "帽子洗发"
    },
    {
      "start": 532.26,
      "end": 533.62,
      "text": "76分钟"
    },
    {
      "start": 533.62,
      "end": 534.98,
      "text": "球王梅西"
    },
    {
      "start": 534.98,
      "end": 536.14,
      "text": "中章之舞的"
    },
    {
      "start": 536.14,
      "end": 536.78,
      "text": "特克"
    },
    {
      "start": 536.78,
      "end": 537.74,
      "text": "在现在"
    },
    {
      "start": 537.74,
      "end": 538.62,
      "text": "上演了"
    },
    {
      "start": 538.62,
      "end": 539.94,
      "text": "帽子洗发"
    },
    {
      "start": 539.94,
      "end": 541.78,
      "text": "这场比赛面对二级压"
    },
    {
      "start": 541.78,
      "end": 543.62,
      "text": "国际足连排名第28"
    },
    {
      "start": 543.62,
      "end": 544.54,
      "text": "整场比赛"
    },
    {
      "start": 544.54,
      "end": 546.86,
      "text": "战术布置的相当严密"
    },
    {
      "start": 546.86,
      "end": 547.9,
      "text": "但是奈何"
    },
    {
      "start": 547.9,
      "end": 550.3,
      "text": "面前是球王梅西"
    },
    {
      "start": 550.3,
      "end": 551.94,
      "text": "最终的帽子洗发"
    },
    {
      "start": 551.94,
      "end": 555.5,
      "text": "也是彻底可以奔场比赛"
    },
    {
      "start": 555.5,
      "end": 557.02,
      "text": "画上一个句号"
    },
    {
      "start": 557.02,
      "end": 559.18,
      "text": "这场比赛可以提前恭喜阿根廷"
    },
    {
      "start": 559.22,
      "end": 560.42,
      "text": "拿下胜利"
    },
    {
      "start": 560.42,
      "end": 561.26,
      "text": "冠人之后"
    },
    {
      "start": 561.26,
      "end": 562.82,
      "text": "前场的这个拼抢"
    },
    {
      "start": 562.82,
      "end": 564.38,
      "text": "这个硬度提升上来"
    },
    {
      "start": 564.38,
      "end": 566.06,
      "text": "包括活力都提高了"
    },
    {
      "start": 566.06,
      "end": 567.3,
      "text": "那么就相当不错"
    },
    {
      "start": 567.3,
      "end": 567.74,
      "text": "同时呢"
    },
    {
      "start": 567.74,
      "end": 570.1,
      "text": "也是刚晃送上的世纪助攻了"
    },
    {
      "start": 570.1,
      "end": 570.86,
      "text": "这帽子洗发"
    },
    {
      "start": 570.86,
      "end": 572.18,
      "text": "刚晃也能流明了"
    },
    {
      "start": 572.18,
      "end": 572.9,
      "text": "往前插"
    },
    {
      "start": 572.9,
      "end": 573.62,
      "text": "往前跑"
    },
    {
      "start": 573.62,
      "end": 574.9,
      "text": "把球给到糊顶前"
    },
    {
      "start": 574.9,
      "end": 575.5,
      "text": "梅西"
    },
    {
      "start": 575.5,
      "end": 577.3,
      "text": "今天三次功夫"
    },
    {
      "start": 577.3,
      "end": 579.38,
      "text": "齐达那把手的大门啊"
    },
    {
      "start": 585.61,
      "end": 586.37,
      "text": "最后时刻上"
    },
    {
      "start": 586.37,
      "end": 587.49,
      "text": "马球王来救一救"
    },
    {
      "start": 587.49,
      "end": 589.33,
      "text": "马克雷斯王右侧"
    },
    {
      "start": 589.33,
      "end": 590.13,
      "text": "直接转过去"
    },
    {
      "start": 590.13,
      "end": 593.02,
      "text": "德炮也赶到"
    },
    {
      "start": 593.06,
      "end": 594.18,
      "text": "真狠"
    },
    {
      "start": 594.18,
      "end": 595.34,
      "text": "这是一甲过人王"
    },
    {
      "start": 595.34,
      "end": 596.7,
      "text": "这眼神多么坚毅"
    },
    {
      "start": 597.98,
      "end": 598.38,
      "text": "好了"
    },
    {
      "start": 598.38,
      "end": 599.62,
      "text": "主菜饭黄马金亚克"
    },
    {
      "start": 599.62,
      "end": 601.74,
      "text": "出现了全场比赛的结束哨声"
    },
    {
      "start": 601.74,
      "end": 602.34,
      "text": "梅西"
    },
    {
      "start": 602.34,
      "end": 604.66,
      "text": "二六年世界杯的首秀"
    },
    {
      "start": 604.66,
      "end": 606.5,
      "text": "上演了帽子洗发"
    },
    {
      "start": 606.5,
      "end": 608.3,
      "text": "也是祖函历史"
    },
    {
      "start": 608.3,
      "end": 611.14,
      "text": "第一位连续六届"
    },
    {
      "start": 611.14,
      "end": 613.5,
      "text": "都有登场世界杯的球员"
    }
  ]
}