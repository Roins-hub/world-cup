    {
      "start": 420.91,
      "end": 423.47,
      "text": "否则就要出现大四戏了"
    },
    {
      "start": 423.47,
      "end": 425.11,
      "text": "第四个问题"
    },
    {
      "start": 425.11,
      "end": 426.43,
      "text": "让球迷拆展"
    },
    {
      "start": 426.43,
      "end": 428.27,
      "text": "在梅西不下场的情况下"
    },
    {
      "start": 428.27,
      "end": 429.27,
      "text": "能不能大四戏"
    },
    {
      "start": 429.27,
      "end": 430.03,
      "text": "地场要不要直接"
    },
    {
      "start": 430.03,
      "end": 431.79,
      "text": "把克罗泽的记录给破掉"
    },
    {
      "start": 431.79,
      "end": 433.51,
      "text": "独享世界魅力的队友"
    },
    {
      "start": 433.51,
      "end": 436.42,
      "text": "现在是平了"
    },
    {
      "start": 436.42,
      "end": 437.94,
      "text": "一场比赛"
    },
    {
      "start": 437.94,
      "end": 439.66,
      "text": "先是第一个进球"
    },
    {
      "start": 439.66,
      "end": 441.06,
      "text": "是追平了盖德·穆勒"
    },
    {
      "start": 441.06,
      "end": 442.02,
      "text": "第二个进球"
    },
    {
      "start": 442.02,
      "end": 443.86,
      "text": "是追平了罗纳尔多"
    },
    {
      "start": 443.86,
      "end": 444.62,
      "text": "第三个进球"
    },
    {
      "start": 444.62,
      "end": 446.3,
      "text": "是追平了克罗泽"
    },
    {
      "start": 446.3,
      "end": 447.02,
      "text": "谁能做到"
    },
    {
      "start": 447.02,
      "end": 448.42,
      "text": "那再进一个球的话"
    },
    {
      "start": 448.42,
      "end": 449.62,
      "text": "就没有人可以追越了"
    },
    {
      "start": 449.62,
      "end": 452.69,
      "text": "只能追越自己"
    },
    {
      "start": 452.69,
      "end": 455.93,
      "text": "他自己都笑"
    },
    {
      "start": 455.93,
      "end": 456.73,
      "text": "换我吗"
    },
    {
      "start": 456.73,
      "end": 457.09,
      "text": "你看"
    },
    {
      "start": 457.09,
      "end": 459.01,
      "text": "太神奇了"
    },
    {
      "start": 459.01,
      "end": 459.85,
      "text": "要给他鼓掌"
    },
    {
      "start": 459.85,
      "end": 460.17,
      "text": "真的要给他"
    },
    {
      "start": 460.17,
      "end": 462.37,
      "text": "太神奇了"
    },
    {
      "start": 462.37,
      "end": 463.85,
      "text": "就是连"
    },
    {
      "start": 463.85,
      "end": 465.97,
      "text": "可能最滋生的梅西球迷们"
    },
    {
      "start": 465.97,
      "end": 467.57,
      "text": "对本届的梅西都没有过"
    },
    {
      "start": 467.57,
      "end": 468.73,
      "text": "这样的奢望"
    },
    {
      "start": 468.73,
      "end": 470.61,
      "text": "是的"
    },
    {
      "start": 470.61,
      "end": 471.25,
      "text": "30"
    },
    {
      "start": 471.25,
      "end": 472.65,
      "text": "马上就是要过39期"
    },
    {
      "start": 472.65,
      "end": 476.74,
      "text": "终岁的生日了"
    },
    {
      "start": 476.74,
      "end": 477.82,
      "text": "阿根廷的球迷"
    },
    {
      "start": 477.82,
      "end": 478.66,
      "text": "看场面的表情"
    },
    {
      "start": 478.66,
      "end": 480.02,
      "text": "都是不是狂欢"
    },
    {
      "start": 480.02,
      "end": 481.82,
      "text": "就他们也有点难以理解"
    },
    {
      "start": 481.82,
      "end": 484.14,
      "text": "这怎么可能呢"
    },
    {
      "start": 484.14,
      "end": 485.02,
      "text": "好的 这样来自"
    },
    {
      "start": 485.02,
      "end": 486.78,
      "text": "波兰的主裁判马琪娅克"
    },
    {
      "start": 486.78,
      "end": 487.54,
      "text": "吹响的选场比赛"
    },
    {
      "start": 487.54,
      "end": 488.46,
      "text": "结束的哨音"
    },
    {
      "start": 488.46,
      "end": 489.42,
      "text": "凭借着"
    },
    {
      "start": 489.42,
      "end": 490.82,
      "text": "梅西的帽子系法"
    },
    {
      "start": 490.82,
      "end": 493.02,
      "text": "阿根廷队在本届世界杯的首战"
    },
    {
      "start": 493.02,
      "end": 494.06,
      "text": "是3-0"
    },
    {
      "start": 494.06,
      "end": 495.3,
      "text": "战胜了二级利亚"
    },
    {
      "start": 495.3,
      "end": 497.14,
      "text": "开启了自己本届世界杯的"
    },
    {
      "start": 497.14,
      "end": 498.22,
      "text": "未免征程"
    }
  ]
}