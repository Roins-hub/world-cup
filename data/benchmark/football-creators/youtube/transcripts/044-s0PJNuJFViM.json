    },
    {
      "start": 5.2,
      "end": 6.4,
      "text": "再给厨房各种四散停"
    },
    {
      "start": 6.4,
      "end": 8.04,
      "text": "这样就有更多时间可以加广告了"
    },
    {
      "start": 8.04,
      "end": 9.44,
      "text": "即一场世界杯球组赛看下来"
