    {
      "start": 129.68,
      "end": 130.4,
      "text": "又不是时间到了"
    },
    {
      "start": 130.4,
      "end": 131.2,
      "text": "自动出发剧本的"
    },
    {
      "start": 131.2,
      "end": 131.84,
      "text": "土超连赛"
    },
    {
      "start": 131.84,
      "end": 132.48,
      "text": "由此也能看出"
    },
    {
      "start": 132.48,
      "end": 133.36,
      "text": "本土连赛的健康"
    },
    {
      "start": 133.36,
      "end": 135.16,
      "text": "对国家队竞争力有多么重要"
    },
    {
      "start": 135.16,
      "end": 136.36,
      "text": "土耳其上一次参加世界杯正赛"
    },
    {
      "start": 136.36,
      "end": 137.16,
      "text": "和我们中国男足一样"
    },
    {
      "start": 138.0,
      "end": 138.56,
      "text": "不过那一届"
    },
    {
      "start": 138.56,
      "end": 139.72,
      "text": "他们取得了第三名的好成绩"
    },
    {
      "start": 139.72,
      "end": 140.36,
      "text": "这24年来"
    },
    {
      "start": 140.36,
      "end": 141.04,
      "text": "虽然无缘正赛"
    },
    {
      "start": 141.04,
      "end": 142.28,
      "text": "但在欧洲杯等其他赛之中"
    },
    {
      "start": 142.28,
      "end": 143.04,
      "text": "也有竞争力"
    },
    {
      "start": 143.04,
      "end": 144.4,
      "text": "本以为折腹24年的土耳其"
    },
    {
      "start": 144.4,
      "end": 145.48,
      "text": "这次会是恶能出山"
    },
    {
      "start": 145.48,
      "end": 147.24,
      "text": "没想到还是改不了哈士奇的作风"
    },
    {
      "start": 147.24,
      "end": 148.28,
      "text": "看完土耳其的这两场比赛"
    },
    {
      "start": 148.28,
      "end": 149.48,
      "text": "我真想给西班牙提个醒"
    },
    {
      "start": 149.48,
      "end": 150.84,
      "text": "控球真的不能赢得比赛"
    },
    {
      "start": 150.84,
      "end": 152.24,
      "text": "哪怕你拿到100%的控球率"
    },
    {
      "start": 152.24,
      "end": 153.12,
      "text": "攻不破对方大门"
    },
    {
      "start": 153.12,
      "end": 153.72,
      "text": "也是屠牢"
    },
    {
      "start": 153.72,
      "end": 155.12,
      "text": "希望人称小土耳其的西班牙"
    },
    {
      "start": 155.12,
      "end": 155.92,
      "text": "那么凶凶一点"
    },
    {
      "start": 155.92,
      "end": 156.56,
      "text": "你们的处境"
    },
    {
      "start": 156.56,
      "end": 157.68,
      "text": "真不比土耳其好多少"
    }
  ]
}