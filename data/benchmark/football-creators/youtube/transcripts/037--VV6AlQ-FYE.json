    {
      "start": 143.68,
      "end": 144.92,
      "text": "以三胜三平的不外战技"
    },
    {
      "start": 144.92,
      "end": 146.08,
      "text": "与巴拿马海地一起"
    },
    {
      "start": 146.08,
      "end": 147.32,
      "text": "直接进入世界盃正赛"
    },
    {
      "start": 147.32,
      "end": 148.24,
      "text": "假如那三位老大哥"
    },
    {
      "start": 148.24,
      "end": 149.28,
      "text": "也要踢预选赛的话"
    },
    {
      "start": 149.28,
      "end": 151.08,
      "text": "这个名额估计就轮不到库拉索了"
    },
    {
      "start": 151.08,
      "end": 151.52,
      "text": "说白了"
    },
    {
      "start": 151.52,
      "end": 152.32,
      "text": "库拉索能进世界盃"
    },
    {
      "start": 152.32,
      "end": 153.72,
      "text": "其实靠的是天时与地利"
    },
    {
      "start": 153.72,
      "end": 155.2,
      "text": "天时是河南足球体系的书写"
    },
    {
      "start": 155.2,
      "end": 156.36,
      "text": "地利则是中美美地区的"
    },
    {
      "start": 156.36,
      "end": 157.68,
      "text": "于南太多 竞争太小"
    },
    {
      "start": 157.68,
      "end": 158.84,
      "text": "但能在世界盃正赛"
    },
    {
      "start": 158.84,
      "end": 159.96,
      "text": "踢进德国对一个球"
    },
    {
      "start": 159.96,
      "end": 161.56,
      "text": "那绝对是100%的人和"
    },
    {
      "start": 161.56,
      "end": 163.56,
      "text": "是100%的个人努力结果了"
    }
  ]
}