      "text": "然而更離譜的是"
    },
    {
      "start": 112.84,
      "end": 113.36,
      "text": "美国人不管"
    },
    {
      "start": 113.36,
      "end": 113.88,
      "text": "办什么比赛"
    },
    {
      "start": 113.88,
      "end": 114.64,
      "text": "都喜欢给你搞个"
    },
    {
      "start": 114.64,
      "end": 115.16,
      "text": "联盟制"
    },
    {
      "start": 115.16,
      "end": 116.0,
      "text": "MLS大联盟"
    },
    {
      "start": 116.0,
      "end": 116.92,
      "text": "一共有30级球队"
    },
    {
      "start": 116.92,
      "end": 117.48,
      "text": "和NBA一样"
    },
    {
      "start": 117.48,
      "end": 118.12,
      "text": "分成东西部"
    },
    {
      "start": 118.12,
      "end": 119.28,
      "text": "大家先打三四轮成功赛"
    },
    {
      "start": 119.28,
      "end": 120.04,
      "text": "然后东西办区"
    },
    {
      "start": 120.04,
      "end": 120.8,
      "text": "排名前期的球队"
    },
    {
      "start": 120.8,
      "end": 121.4,
      "text": "建筑机后赛"
    },
    {
      "start": 121.4,
      "end": 121.96,
      "text": "第八合地球"
    },
    {
      "start": 121.96,
      "end": 122.48,
      "text": "进行附加赛"
    },
    {
      "start": 122.48,
      "end": 123.12,
      "text": "却足最后一个"
    },
    {
      "start": 123.12,
      "end": 123.72,
      "text": "几乎赛名额"
    },
    {
      "start": 123.72,
      "end": 124.64,
      "text": "然后是三轮两回合的"
    },
    {
      "start": 124.64,
      "end": 124.96,
      "text": "几乎赛"
    },
    {
      "start": 124.96,
      "end": 125.88,
      "text": "接着才是总决赛"
    },
    {
      "start": 125.88,
      "end": 126.48,
      "text": "和其他国家的"
    },
    {
      "start": 126.48,
      "end": 127.16,
      "text": "足球联赛制度"
    },
    {
      "start": 127.16,
      "end": 128.0,
      "text": "完全不一样"
    },
    {
      "start": 128.0,
      "end": 128.6,
      "text": "你可以理解为"
    },
    {
      "start": 128.6,
      "end": 129.56,
      "text": "T足球的NBA"
    },
    {
      "start": 129.56,
      "end": 129.96,
      "text": "关键是"
    },
    {
      "start": 129.96,
      "end": 130.68,
      "text": "美国的足球联赛"
    },
    {
      "start": 130.68,
      "end": 131.56,
      "text": "也没有升降级"
    },
    {
      "start": 131.56,
      "end": 132.36,
      "text": "排名垫底的球队"
    },
    {
      "start": 132.36,
      "end": 133.0,
      "text": "非但不会倒入"
    },
    {
      "start": 133.0,
      "end": 133.52,
      "text": "刺激联赛"
    },
    {
      "start": 133.52,
      "end": 134.16,
      "text": "反而还能拿到"
    },
    {
      "start": 134.16,
      "end": 135.2,
      "text": "顺便较高的选修务权"
    },
    {
      "start": 135.2,
      "end": 135.92,
      "text": "想将天赋更好的"
    },
    {
      "start": 135.92,
      "end": 136.8,
      "text": "年轻人加入球队"
    },
    {
      "start": 136.8,
      "end": 137.8,
      "text": "这种制度的商业价值"
    },
    {
      "start": 137.8,
      "end": 138.64,
      "text": "当然是最大化的"
    },
    {
      "start": 138.64,
      "end": 138.92,
      "text": "那对于"
    },
    {
      "start": 138.92,
      "end": 139.96,
      "text": "提升足球实力的帮助"
    },
    {
      "start": 139.96,
      "end": 140.64,
      "text": "实在有限"
    },
    {
      "start": 140.64,
      "end": 141.48,
      "text": "将来会和NBA一样"
    },
    {
      "start": 141.48,
      "end": 142.56,
      "text": "出现超年摆烂球队"
    },
    {
      "start": 142.56,
      "end": 143.72,
      "text": "也导致了足球在美国"
    },
    {
      "start": 143.72,
      "end": 144.44,
      "text": "不像其他运动的"
    },
    {
      "start": 144.44,
      "end": 145.24,
      "text": "发展程度那么高"
    },
    {
      "start": 145.24,
      "end": 145.8,
      "text": "而今年成功"
    },
    {
      "start": 145.8,
      "end": 146.4,
      "text": "举办世界盃后"
    },
    {
      "start": 146.4,
      "end": 147.12,
      "text": "肯定会对美国的"
    },
    {
      "start": 147.12,
      "end": 148.2,
      "text": "足球发展带来帮助"
    },
    {
      "start": 148.2,
      "end": 149.2,
      "text": "不论MLS的市值"
    },
    {
      "start": 149.2,
      "end": 149.76,
      "text": "还是影响力"
    },
    {
      "start": 149.76,
      "end": 150.4,
      "text": "起码都会持续"
    },
    {
      "start": 150.4,
      "end": 151.16,
      "text": "提升一两年"
    },
    {
      "start": 151.2,
      "end": 151.8,
      "text": "恒天也会吸引"
    },
    {
      "start": 151.8,
      "end": 152.44,
      "text": "更多的年轻人"
    },
    {
      "start": 152.44,
      "end": 153.2,
      "text": "去参与足球"
    },
    {
      "start": 153.2,
      "end": 153.84,
      "text": "但不太可能"
    },
    {
      "start": 153.84,
      "end": 154.36,
      "text": "牺牲前四"
    },
    {
      "start": 154.36,
      "end": 154.6,
      "text": "毕竟"
    },
    {
      "start": 154.6,
      "end": 155.12,
      "text": "提约土扰"
    },
    {
      "start": 155.12,
      "end": 156.28,
      "text": "是多年沉淀下来的"
    },
    {
      "start": 156.28,
      "end": 157.12,
      "text": "世界盃的影响力"
    },
    {
      "start": 157.12,
      "end": 157.48,
      "text": "再大"
    },
    {
      "start": 157.48,
      "end": 157.88,
      "text": "也不足以"
    },
    {
      "start": 157.88,
      "end": 158.92,
      "text": "含动四大联盟的根基"
    },
    {
      "start": 158.92,
      "end": 159.32,
      "text": "不信"
    },
    {
      "start": 159.32,
      "end": 160.04,
      "text": "你可以问问美国人"
    },
    {
      "start": 160.04,
      "end": 160.72,
      "text": "他们是更用期待"
    },
    {
      "start": 160.72,
      "end": 161.56,
      "text": "四年一度的世界盃"
    },
    {
      "start": 161.56,
      "end": 162.04,
      "text": "还是更用期待"
    },
    {
      "start": 162.04,
      "end": 162.64,
      "text": "每年一次的"
    },
    {
      "start": 162.64,
      "end": 163.04,
      "text": "钢铃球"
    },
    {
      "start": 163.04,
      "end": 163.68,
      "text": "超级晚"
    }
  ]
}