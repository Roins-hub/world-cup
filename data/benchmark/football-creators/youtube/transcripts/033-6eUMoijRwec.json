    {
      "start": 130.48,
      "end": 131.56,
      "text": "放在哪里都可能给红牌"
    },
    {
      "start": 131.56,
      "end": 132.96,
      "text": "马特拉齐的老弟也并非演戏"
    },
    {
      "start": 132.96,
      "end": 134.32,
      "text": "但全世界球迷都表示"
    },
    {
      "start": 134.32,
      "end": 135.12,
      "text": "理解齐达内"
    },
    {
      "start": 135.12,
      "end": 136.68,
      "text": "虽然意大利最终获得世界盖决赛"
    },
    {
      "start": 136.68,
      "end": 138.16,
      "text": "但马特拉齐就被永远定在"
    },
    {
      "start": 138.16,
      "end": 138.8,
      "text": "支付柱上"
    },
    {
      "start": 138.8,
      "end": 140.0,
      "text": "上届卡特尔世界盖开始前"
    },
    {
      "start": 140.0,
      "end": 140.68,
      "text": "多哈的球馆前"
    },
    {
      "start": 140.68,
      "end": 141.72,
      "text": "还展出了这样一座雕像"
    },
    {
      "start": 141.72,
      "end": 143.68,
      "text": "就是齐达内投顶马特拉齐的瞬间"
    },
    {
      "start": 143.68,
      "end": 144.68,
      "text": "威拉规处然索尔雷斯"
    },
    {
      "start": 144.68,
      "end": 145.68,
      "text": "在实业碑上有归一张"
    },
    {
      "start": 145.68,
      "end": 146.68,
      "text": "改变时间线的红牌"
    },
    {
      "start": 146.68,
      "end": 147.12,
      "text": "2010年"
    },
    {
      "start": 147.12,
      "end": 148.32,
      "text": "南非世界碑四分之一决赛"
    },
    {
      "start": 148.32,
      "end": 149.16,
      "text": "威拉规队震加纳"
    },
    {
      "start": 149.16,
      "end": 150.0,
      "text": "假设在最后时刻"
    },
    {
      "start": 150.0,
      "end": 151.36,
      "text": "加纳的投球眼看又进门了"
    },
    {
      "start": 151.36,
      "end": 152.32,
      "text": "索尔雷斯情急之下"
    },
    {
      "start": 152.32,
      "end": 153.8,
      "text": "实际下来的个闷将扑就动作"
    },
    {
      "start": 153.8,
      "end": 154.96,
      "text": "虽然裁判给了索尔雷斯红牌"
    },
    {
      "start": 154.96,
      "end": 155.88,
      "text": "也给了加纳点球"
    },
    {
      "start": 155.88,
      "end": 156.56,
      "text": "但阿萨莫阿"
    },
    {
      "start": 156.56,
      "end": 158.24,
      "text": "几安主乏的点球居然踢飞了"
    },
    {
      "start": 158.24,
      "end": 159.04,
      "text": "最后的点球大战"
    },
    {
      "start": 159.04,
      "end": 160.12,
      "text": "威拉规也淘汰了加纳"
    },
    {
      "start": 160.12,
      "end": 161.44,
      "text": "索尔雷斯虽然犯规被罚下"
    },
    {
      "start": 161.44,
      "end": 162.92,
      "text": "但他却成了威拉规队的英雄"
    }
  ]
}